{
  "name": "foai-capstone-fixed-webhook_scaler",
  "nodes": [
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are an intake classifier agent for Scaler School of Technology's \nstudent support system.\nYour job is to classify the student's message by topic and urgency.\n\nContext about Scaler School of Technology:\n- Technology college with BS in Technology program\n- Common student issues: attendance, assignments, fees, placements, \n  technical problems, schedule queries, NSAT admissions\n- Departments: Academics, Admissions, Finance, Student Affairs, Technical\n\nReturn ONLY a valid JSON object:\n{\n  \"topic\": one of [\"academics\", \"admissions\", \"fees\", \"technical\", \"general\"],\n  \"urgency\": number 1 to 5,\n  \"summary\": one sentence summary of the issue\n}\n\nTopic guidelines:\n- academics: assignments, attendance, grades, courses, instructors, schedule\n- admissions: NSAT, enrollment, documents, joining process\n- fees: payment, refund, scholarship, fee structure\n- technical: platform issues, login problems, app crashes, portal errors\n- general: campus life, events, placements, general queries\n\nUrgency rules:\n- 1-2: general question, low priority\n- 3: normal issue needing resolution\n- 4-5: angry student, urgent deadline, financial issue, exam problem\n\nStudent message: {{ $json.message }}\nRespond ONLY with valid JSON. No extra text, no markdown.",
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        1040,
        -416
      ],
      "id": "f5c4c7e7-1abe-41c8-9137-33912a0d6661",
      "name": "Classifier"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a sentiment analyzer agent for Scaler School of Technology's \nstudent support system.\nYour job is to detect the emotional tone of the student message.\n\nContext: Students may be stressed about assignments, attendance, \nfees, placements, or technical issues. Be sensitive to academic stress.\n\nReturn ONLY a valid JSON object:\n{\n  \"sentiment\": one of [\"positive\", \"neutral\", \"negative\"],\n  \"mood\": one of [\"casual\", \"neutral\", \"angry\"],\n  \"score\": float from 0.0 (very negative) to 1.0 (very positive),\n  \"flags\": array of detected emotions e.g. [\"stressed\", \"frustrated\", \"confused\", \"anxious\"],\n  \"escalate\": true if mood is angry OR score < 0.3, else false\n}\n\nMood rules:\n- casual: friendly, simple question, positive feedback\n- neutral: normal support request, general query\n- angry: frustrated, upset, threatening to leave, extremely stressed\n\nStudent message: {{ $json.message }}\nRespond ONLY with valid JSON. No extra text, no markdown.",
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        1056,
        -112
      ],
      "id": "fbe1321f-6baa-4702-b8e3-e4876484e11e",
      "name": "Sentiment"
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.text || $input.first().json.output || '';\nconst cleaned = raw.replace(/```json|```/g, '').trim();\nconst parsed = JSON.parse(cleaned);\n\nreturn [{\n  json: {\n    message: $('Faq classifier parser').first().json.message,\n    topic: parsed.topic,\n    urgency: parsed.urgency,\n    summary: parsed.summary\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1456,
        -336
      ],
      "id": "d4822c05-4fd9-49bd-a905-75eb90079fee",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.text || $input.first().json.output || '';\nconst cleaned = raw.replace(/```json|```/g, '').trim();\nconst parsed = JSON.parse(cleaned);\n\nreturn [{\n  json: {\n    sentiment: parsed.sentiment,\n    mood: parsed.mood,\n    score: parsed.score,\n    flags: parsed.flags,\n    escalate: parsed.escalate\n  }\n}];"
      },
